# Copy to .env and edit values for your local/prod environment.

# Core database connection
DATABASE_URL=postgresql+psycopg://iot:replace_me@1.14.58.49:5432/rednote_spider

# UI runtime mode: dev / production
APP_ENV=production

# Required when APP_ENV=production
STREAMLIT_ACCESS_TOKEN=replace_with_a_long_random_token

# Streamlit server binding (recommended: keep 127.0.0.1 and put Nginx/Caddy in front)
#STREAMLIT_SERVER_ADDRESS=127.0.0.1
#STREAMLIT_SERVER_PORT=8501
#STREAMLIT_SERVER_HEADLESS=true

# Crawl backend is command-only
#CRAWL_BACKEND=command
# Example command backend template:
#CRAWL_COMMAND_TEMPLATE=python external_crawler.py --keywords "{keywords}" --max-notes {max_notes}
# Optional timeout (seconds) for command backend execution
#CRAWL_COMMAND_TIMEOUT_SECONDS=600
#
# Example: MediaCrawler (uv) integration
# 1) make sure MediaCrawler deps are installed:
#    cd /Users/huyaoqi/Documents/MediaCrawler && uv run playwright install
# 2) first login usually needs non-headless QR scan once
#CRAWL_BACKEND=command
#CRAWL_COMMAND_TEMPLATE=python scripts/run_external_crawler.py --keywords "{keywords}" --max-notes {max_notes} --source json-dir --json-dir /Users/huyaoqi/Documents/rednote—spider/crawler_output/xhs/json --crawler-cwd /Users/huyaoqi/Documents/MediaCrawler --crawler-timeout-seconds 600 --probe-cmd "/Users/huyaoqi/Documents/MediaCrawler/.venv/bin/python /Users/huyaoqi/Documents/rednote—spider/scripts/run_mediacrawler_login_only.py --platform xhs --method probe" --crawler-cmd "/Users/huyaoqi/Documents/MediaCrawler/.venv/bin/python /Users/huyaoqi/Documents/rednote—spider/scripts/run_mediacrawler_with_terminal_qr.py --platform xhs --lt qrcode --type search --keywords \"{keywords}\" --save_data_option json --save_data_path /Users/huyaoqi/Documents/rednote—spider/crawler_output --get_comment true --headless true"

# Discover/Opportunity supervisor loop defaults (UI 可覆盖 discover/opportunity)
#SCHED_DISCOVER_LOOP_INTERVAL_SECONDS=900
#SCHED_OPPORTUNITY_LOOP_INTERVAL_SECONDS=600

# Optional: observability log level
#LOG_LEVEL=INFO

# Unified MediaCrawler login runtime
# Streamlit 只做控制台，真实登录状态以 MediaCrawler 持久浏览器 profile + pong() 为准
#LOGIN_RUNTIME_PYTHON=/root/MediaCrawler/.venv/bin/python
#LOGIN_RUNTIME_CRAWLER_CWD=../MediaCrawler
#LOGIN_CONTROLLER_POLL_SECONDS=2

# Legacy split QR/phone worker settings remain readable for compatibility,
# but the primary managed path is now:
# scripts/run_login_qr_worker.py -> unified login controller
# scripts/run_mediacrawler_login_only.py -> login-only MediaCrawler runtime

# Opportunity pipeline LLM config (prescreen / match-or-create / scoring)
# OPPORTUNITY_LLM_PROVIDER=openai
# OPPORTUNITY_LLM_API_KEY=sk-...
# OPPORTUNITY_LLM_BASE_URL=https://api.openai.com/v1
# OPPORTUNITY_LLM_MODEL=gpt-4.1-mini
# OPPORTUNITY_LLM_TIMEOUT_SECONDS=600
# OPPORTUNITY_LLM_TEMPERATURE=0.1

# Scheduler login-expiry alert (QQ SMTP)
# Triggered by scripts/run_scheduled_loop.sh when cycle fails and logs look like login expiry/scan issues.
#SCHED_LOGIN_ALERT_ENABLED=true
#SCHED_LOGIN_ALERT_FROM_EMAIL=your_qq@qq.com
#SCHED_LOGIN_ALERT_TO_EMAIL=your_qq@qq.com
#SCHED_LOGIN_ALERT_PASSWORD=your_qq_smtp_auth_code
#SCHED_LOGIN_ALERT_SMTP_HOST=smtp.qq.com
#SCHED_LOGIN_ALERT_SMTP_PORT=465
#SCHED_LOGIN_ALERT_COOLDOWN_SECONDS=21600
