SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin

# Replace __PROJECT_DIR__ with your absolute project path.
# Ensure __PROJECT_DIR__/logs exists before enabling cron.

# Discover crawl every 15 minutes.
*/15 * * * * cd __PROJECT_DIR__ && bash scripts/run_scheduled_cycle.sh discover >> logs/scheduler-discover.log 2>&1
